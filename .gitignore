# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
ESGC/Binaries/*
Plugins/**/Binaries/*
ESGC/Plugins/*/Binaries/*

# Builds
Build/*
ESGC/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!ESGC/Build/*/
ESGC/Build/*/**
!ESGC/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico
!ESGC/Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*
ESGC/Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*
ESGC/Intermediate/*
ESGC/Plugins/*/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*
ESGC/DerivedDataCache/*
ESGC/Content/CT_Components/Demos/EpicContents/LyraContent/Effects/Textures/Flipbooks/SmokeSwirl_3_Flipbook_CHANNELPACK.uasset
ESGC/Content/Developers/*
ESGC/Content/Collections/*
